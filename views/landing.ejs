<script>
  // ── INTERSECTION OBSERVER for scroll animations ──
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        // stagger delay based on sibling index
        const siblings = entry.target.parentElement.querySelectorAll(
          '.feat-card, .dcard, .sbox, .reveal'
        );
        let idx = Array.from(siblings).indexOf(entry.target);
        if (idx < 0) idx = 0;
        setTimeout(() => {
          entry.target.classList.add('visible');
        }, idx * 80);
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.feat-card, .dcard, .sbox, .reveal').forEach(el => {
    observer.observe(el);
  });

  // About section
  const aboutObs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        aboutObs.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });
  document.querySelectorAll('.about-text').forEach(el => aboutObs.observe(el));

  // Stat boxes stagger
  const statObs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        document.querySelectorAll('.sbox').forEach((box, i) => {
          setTimeout(() => box.classList.add('visible'), i * 100);
        });
        statObs.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });
  const statGrid = document.getElementById('statGrid');
  if (statGrid) statObs.observe(statGrid);

  // ── CHATBOT ──
  let chatOpen = false;

  function toggleChat() {
    chatOpen = !chatOpen;
    const panel = document.getElementById('chatPanel');
    if (chatOpen) {
      panel.style.display = 'flex';
      panel.style.animation = 'chatSlideIn 0.3s ease both';
      document.getElementById('chatIn').focus();
    } else {
      panel.style.animation = 'chatSlideOut 0.2s ease both';
      setTimeout(() => { panel.style.display = 'none'; }, 200);
    }
  }

  // inject chat animations
  const style = document.createElement('style');
  style.textContent = `
    @keyframes chatSlideIn { from { opacity:0; transform: translateY(12px) scale(0.97); } to { opacity:1; transform: translateY(0) scale(1); } }
    @keyframes chatSlideOut { from { opacity:1; transform: translateY(0) scale(1); } to { opacity:0; transform: translateY(8px) scale(0.97); } }
  `;
  document.head.appendChild(style);

  function chipSend(el) {
    document.getElementById('chatIn').value = el.textContent;
    document.getElementById('chipsRow').style.display = 'none';
    sendMsg();
  }

  let hist = [], loading = false;

  function appendMsg(txt, role) {
    const m = document.getElementById('chatMsgs');
    const d = document.createElement('div');
    d.className = 'msg ' + (role === 'user' ? 'msg-user' : 'msg-bot');
    d.textContent = txt;
    m.appendChild(d);
    m.scrollTop = m.scrollHeight;
  }

  function showTyping() {
    const m = document.getElementById('chatMsgs');
    const d = document.createElement('div');
    d.className = 'msg msg-bot'; d.id = 'tyEl';
    d.innerHTML = '<div class="typing-d"><div class="td"></div><div class="td"></div><div class="td"></div></div>';
    m.appendChild(d); m.scrollTop = m.scrollHeight;
  }

  async function sendMsg() {
    if (loading) return;
    const inp = document.getElementById('chatIn');
    const txt = inp.value.trim();
    if (!txt) return;
    inp.value = '';
    appendMsg(txt, 'user');
    hist.push({ role: 'user', content: txt });
    loading = true;
    document.getElementById('sendBtn').disabled = true;
    showTyping();
    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'claude-sonnet-4-6',
          max_tokens: 1000,
          system: `You are the friendly AI travel guide for TravelCravings — a full-stack accommodation listing platform built by Khushi Singh (GitHub: Khushisgh01). Features: accommodation categories (beaches, mountains, castles, camping, lakeside, urban), Mapbox live maps, star reviews, Cloudinary image uploads, Passport.js auth, GST price toggle, full CRUD for listings. Give warm, helpful travel advice — best seasons, packing tips, local culture, and how to use the site. Keep replies to 2–4 sentences unless a list genuinely helps.`,
          messages: hist
        })
      });
      const data = await res.json();
      const el = document.getElementById('tyEl'); if (el) el.remove();
      const reply = data.content?.[0]?.text || 'Oops — try again!';
      hist.push({ role: 'assistant', content: reply });
      appendMsg(reply, 'bot');
    } catch(e) {
      const el = document.getElementById('tyEl'); if (el) el.remove();
      appendMsg('Network hiccup — please try again!', 'bot');
    }
    loading = false;
    document.getElementById('sendBtn').disabled = false;
  }
</script>
