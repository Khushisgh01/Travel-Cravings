<% layout("/layouts/boilerplate") %>

    <style>
      #filters {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
      }
      .filter {
        text-align: center;
        margin-right: 2rem;
        margin-top: 2rem;
        opacity: 0.7;
        cursor: pointer;
        transition: 0.3s;
      }
      .filter a {
        text-decoration: none;
        color: inherit;
        display: block;
      }
      .filter:hover {
        opacity: 1;
        cursor: pointer;
      }
      .filter p {
        font-size: 0.8rem;
        margin-top: 0.4rem;
      }
      .filter.active {
        opacity: 1;
        color: var(--brand-color, #fe424d);
        border-bottom: 2px solid var(--brand-color, #fe424d);
        padding-bottom: 0.4rem;
      }
      .tax-info {
        display: none;
      }
      .tax-toggle {
        border: 1px solid black;
        border-radius: 1rem;
        height: 3.25rem;
        padding: 1rem;
        margin-left: 2rem;
        display: flex;
        align-items: center;
      }
      .no-results {
        text-align: center;
        padding: 4rem 1rem;
        color: #717171;
      }
      .no-results p {
        margin-top: 1rem;
        font-size: 1rem;
      }
    </style>

    <%
      const filters = [
        { key: "trending", icon: "fa-solid fa-fire", label: "Trending" },
        { key: "rooms", icon: "fa-solid fa-bed", label: "Rooms" },
        { key: "iconic_cities", icon: "fa-solid fa-city", label: "Iconic Cities" },
        { key: "mountains", icon: "fa-solid fa-mountain-sun", label: "Mountains" },
        { key: "castles", icon: "fa-brands fa-fort-awesome", label: "Castles" },
        { key: "pools", icon: "fa-solid fa-person-swimming", label: "Amazing Pools" },
        { key: "camping", icon: "fa-solid fa-campground", label: "Camping" },
        { key: "farms", icon: "fa-solid fa-cow", label: "Farms" },
        { key: "arctic", icon: "fa-regular fa-snowflake", label: "Arctic" },
        { key: "domes", icon: "fa-solid fa-igloo", label: "Domes" },
        { key: "boats", icon: "fa-solid fa-sailboat", label: "Boats" },
      ];
    %>

    <div id="filters">
        <% filters.forEach(f => { %>
            <div class="filter <%= category === f.key ? 'active' : '' %>">
                <a href="/listings?category=<%= category === f.key ? '' : f.key %><%= search ? '&search=' + search : '' %>">
                    <div><i class="<%= f.icon %>"></i></div>
                    <p><%= f.label %></p>
                </a>
            </div>
        <% }) %>

       <div class="tax-toggle">
        <div class="form-check-reverse form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
            <label class="form-check-label" for="flexSwitchCheckDefault">Display total after taxes</label>
        </div>
       </div>

    </div>

    <% if (allListings.length === 0) { %>
        <div class="no-results">
            <i class="fa-solid fa-compass" style="font-size:2rem; color:#fe424d;"></i>
            <p>
                No stays found<% if (category && category !== 'all') { %> in this category<% } %><% if (search) { %> for "<%= search %>"<% } %>.
                Try a different filter or search.
            </p>
        </div>
    <% } %>

    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
        <% for(let listing of allListings){ %>
            <a href="/listings/<%= listing._id%>" class="listing-link">
                <div class="card col listing-card">
                    <img src="<%=listing.image.url%>" class="card-img-top" alt="listing_image" style="height: 20rem;">
                    <div class="card-img-overlay"></div>
                    <div class="card-body">
                        <p class="card-text">
                            <b><%= listing.title%></b> <br>
                            &#8377;<%= listing.price.toLocaleString("en-IN")%>/night
                            <i class="tax-info"> &nbsp; &nbsp; +18% GST</i>
                        </p>
                    </div>
                </div>
            </a>
        <%}%>
    </div>

    <script>
        let taxSwitch = document.getElementById("flexSwitchCheckDefault");
        taxSwitch.addEventListener("click", () => {
            let taxInfo = document.getElementsByClassName("tax-info");
            for(info of taxInfo){
                if(info.style.display != "inline"){
                    info.style.display = "inline";
                } else {
                    info.style.display = "none";
                }
            }
        });
    </script>
