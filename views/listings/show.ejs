<% layout("/layouts/boilerplate") %>
<script>
    let mapToken="<%= process.env.MAP_TOKEN %>";
    let coordinates= <%- JSON.stringify(listing.geometry.coordinates) %>;
</script>

<div class="show-wrapper">

  <div class="show-header">
    <h2><%= listing.title %></h2>
    <p class="show-location"><i class="fa-solid fa-location-dot"></i> <%= listing.location %>, <%= listing.country %></p>
  </div>

  <div class="show-grid">

    <div class="show-main">
      <img src="<%= listing.image.url %>" class="show-img" alt="listing_image">

      <div class="show-host-row">
        <div class="host-chip">
          <div class="host-avatar"><%= listing.owner.username.charAt(0).toUpperCase() %></div>
          <div>
            <div class="host-label">Hosted by</div>
            <div class="host-name">@<%= listing.owner.username %></div>
          </div>
        </div>
        <div class="price-chip">
          &#8377;<%= listing.price.toLocaleString("en-IN") %><span> / night</span>
        </div>
      </div>

      <p class="show-desc"><%= listing.description %></p>

      <% if(currUser && listing.owner && currUser._id.equals(listing.owner._id)){ %>
        <div class="owner-actions">
          <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark edit-btn"><i class="fa-solid fa-pen"></i> Edit</a>
          <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
            <button class="btn btn-danger" type="submit"><i class="fa-solid fa-trash"></i> Delete</button>
          </form>
        </div>
      <% } %>

      <hr>

      <div class="reviews-section">
        <h4>Reviews<% if(listing.reviews.length){ %> <span class="review-count">(<%= listing.reviews.length %>)</span><% } %></h4>

        <% if(currUser){ %>
          <form action="/listings/<%= listing.id %>/reviews" method="POST" novalidate class="needs-validation review-form">
            <div class="mb-3 mt-3">
              <label class="form-label">Your rating</label><br>

              <fieldset class="starability-slot">
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1"
                    checked aria-label="No rating." />
                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                <label for="first-rate1" title="Terrible">1 star</label>
                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                <label for="first-rate2" title="Not good">2 stars</label>
                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                <label for="first-rate3" title="Average">3 stars</label>
                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                <label for="first-rate4" title="Very good">4 stars</label>
                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                <label for="first-rate5" title="Amazing">5 stars</label>
              </fieldset>

              <p id="ratingLabel" class="rating-label">Tap a star to choose your rating</p>
            </div>
            <div class="mb-3 mt-3">
              <label for="comment" class="form-label">Comments</label>
              <textarea name="review[comment]" id="comment" cols="30" rows="4" class="form-control"
                  placeholder="Share details of your experience..." required></textarea>
              <div class="invalid-feedback">Please add some comments for review</div>
            </div>
            <button class="btn btn-outline-dark">Submit Review</button>
          </form>
          <hr>
        <% } %>

        <% if(listing.reviews.length > 0){ %>
          <div class="review-grid">
            <% for(review of listing.reviews){ %>
              <div class="review-card">
                <div class="review-card-head">
                  <div class="review-avatar"><%= review.author.username.charAt(0).toUpperCase() %></div>
                  <div>
                    <div class="review-username">@<%= review.author.username %></div>
                    <p class="starability-result" data-rating="<%= review.rating %>"></p>
                  </div>
                </div>
                <p class="review-comment"><%= review.comment %></p>

                <%# Only the person who wrote this review sees a Delete button %>
                <% if(currUser && review.author && currUser._id.equals(review.author._id)){ %>
                  <form method="POST"
                      action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE">
                    <button class="btn btn-sm btn-outline-danger">Delete</button>
                  </form>
                <% } %>
              </div>
            <% } %>
          </div>
        <% } else { %>
          <p class="no-reviews">No reviews yet — be the first to share your experience!</p>
        <% } %>
      </div>
    </div>

    <div class="show-side">
      <h5>Where you'll be</h5>
      <div id="map"></div>
      <p class="map-note">Exact location is provided after booking.</p>
    </div>

  </div>
</div>

<script src="/js/map.js"></script>
<script>
  (function () {
    const ratingLabel = document.getElementById('ratingLabel');
    if (!ratingLabel) return;
    const descriptions = { "1": "Terrible", "2": "Not good", "3": "Average", "4": "Very good", "5": "Amazing" };
    document.querySelectorAll('.starability-slot input[type="radio"]:not(.input-no-rate)').forEach((input) => {
      input.addEventListener('change', () => {
        ratingLabel.textContent =
          input.value + ' star' + (input.value === '1' ? '' : 's') + ' selected — ' + descriptions[input.value];
      });
    });
  })();
</script>
