<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login — TravelCravings</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', sans-serif;
      min-height: 100vh;
      background: #f0f4ff;
      display: flex;
      flex-direction: column;
      overflow-x: hidden;
    }

    /* ── BLOBS ── */
    .blobs {
      position: fixed; inset: 0;
      pointer-events: none; z-index: 0; overflow: hidden;
    }
    .blob { position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.55; }
    .b1 { width: 500px; height: 500px; background: #c7b8ff; top: -120px; left: -100px; animation: m1 14s ease-in-out infinite alternate; }
    .b2 { width: 400px; height: 400px; background: #b8e4ff; bottom: -80px; right: -80px; animation: m2 17s ease-in-out infinite alternate; }
    .b3 { width: 300px; height: 300px; background: #d4f0c8; top: 40%; left: 60%; animation: m3 12s ease-in-out infinite alternate; }
    @keyframes m1 { 0% { border-radius: 60% 40% 30% 70%/60% 30% 70% 40%; transform: translate(0,0); } 100% { border-radius: 40% 60% 70% 30%/40% 70% 30% 60%; transform: translate(40px,60px); } }
    @keyframes m2 { 0% { border-radius: 40% 60% 60% 40%/60% 30% 70% 40%; transform: translate(0,0); } 100% { border-radius: 60% 40% 30% 70%/40% 60% 40% 60%; transform: translate(-40px,-40px); } }
    @keyframes m3 { 0% { border-radius: 50% 50% 60% 40%/40% 60% 50% 60%; transform: translate(0,0); } 100% { border-radius: 60% 40% 40% 60%/60% 40% 60% 40%; transform: translate(30px,-30px); } }

    /* ── NAV ── */
    nav {
      position: relative; z-index: 100;
      padding: 16px 48px;
      display: flex; align-items: center; justify-content: space-between;
      background: rgba(255,255,255,0.5);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(255,255,255,0.65);
      animation: fadeDown 0.5s ease both;
    }
    @keyframes fadeDown { from { opacity:0; transform: translateY(-16px); } to { opacity:1; transform: translateY(0); } }
    .logo {
      font-family: 'Syne', sans-serif; font-size: 20px; font-weight: 800;
      text-decoration: none; color: #1e1b3a;
    }
    .logo span {
      background: linear-gradient(90deg, #7c5cfc, #38b6ff);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .nav-right { display: flex; gap: 16px; align-items: center; }
    .nav-link { color: #5a5478; font-size: 13px; text-decoration: none; transition: color 0.2s; }
    .nav-link:hover { color: #7c5cfc; }
    .nav-btn {
      background: linear-gradient(135deg, #7c5cfc, #38b6ff);
      color: #fff; border: none; padding: 9px 20px;
      border-radius: 50px; font-size: 12px; font-weight: 500;
      text-decoration: none; cursor: pointer;
      box-shadow: 0 4px 16px rgba(124,92,252,0.3);
      transition: opacity 0.2s, transform 0.15s;
    }
    .nav-btn:hover { opacity: 0.88; transform: translateY(-1px); color: #fff; }

    /* ── MAIN ── */
    .auth-wrap {
      flex: 1; position: relative; z-index: 10;
      display: flex; align-items: center; justify-content: center;
      padding: 48px 24px;
    }

    .auth-card {
      width: 100%; max-width: 420px;
      background: rgba(255,255,255,0.6);
      backdrop-filter: blur(28px);
      -webkit-backdrop-filter: blur(28px);
      border: 1px solid rgba(255,255,255,0.85);
      border-radius: 28px;
      padding: 44px 40px;
      box-shadow: 0 20px 64px rgba(124,92,252,0.12), 0 4px 16px rgba(0,0,0,0.04);
      animation: cardIn 0.5s 0.1s cubic-bezier(0.34,1.2,0.64,1) both;
    }
    @keyframes cardIn {
      from { opacity:0; transform: translateY(28px) scale(0.97); }
      to   { opacity:1; transform: translateY(0) scale(1); }
    }

    .auth-icon {
      width: 54px; height: 54px; border-radius: 16px;
      background: linear-gradient(135deg, #7c5cfc, #38b6ff);
      display: flex; align-items: center; justify-content: center;
      font-size: 22px; color: #fff; margin-bottom: 24px;
      box-shadow: 0 8px 24px rgba(124,92,252,0.35);
    }

    .auth-title {
      font-family: 'Syne', sans-serif;
      font-size: 26px; font-weight: 700;
      color: #1e1b3a; letter-spacing: -0.8px;
      margin-bottom: 6px;
    }
    .auth-sub { font-size: 13px; color: #9a94b8; margin-bottom: 32px; }
    .auth-sub a { color: #7c5cfc; text-decoration: none; font-weight: 500; }
    .auth-sub a:hover { text-decoration: underline; }

    /* flash */
    .flash-error {
      background: rgba(239,68,68,0.08);
      border: 1px solid rgba(239,68,68,0.2);
      border-radius: 12px; padding: 10px 14px;
      font-size: 12px; color: #dc2626;
      margin-bottom: 20px; display: flex; align-items: center; gap: 8px;
    }

    /* form */
    .form-group { margin-bottom: 18px; }
    .form-label {
      font-size: 12px; font-weight: 500; color: #5a5478;
      letter-spacing: 0.3px; margin-bottom: 7px; display: block;
    }
    .form-control-custom {
      width: 100%;
      background: rgba(255,255,255,0.7);
      border: 1px solid rgba(124,92,252,0.18);
      border-radius: 14px;
      padding: 12px 16px;
      font-size: 14px; color: #1e1b3a;
      font-family: 'Inter', sans-serif;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
    }
    .form-control-custom:focus {
      border-color: rgba(124,92,252,0.5);
      box-shadow: 0 0 0 4px rgba(124,92,252,0.08);
      background: rgba(255,255,255,0.9);
    }
    .form-control-custom::placeholder { color: #c0bad8; }

    .input-wrap { position: relative; }
    .input-icon {
      position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
      color: #b0aac8; font-size: 13px; pointer-events: none;
    }
    .input-wrap .form-control-custom { padding-left: 38px; }

    .btn-auth {
      width: 100%;
      background: linear-gradient(135deg, #7c5cfc, #38b6ff);
      color: #fff; border: none;
      padding: 13px 24px; border-radius: 14px;
      font-size: 14px; font-weight: 500;
      font-family: 'Inter', sans-serif;
      cursor: pointer; margin-top: 8px;
      box-shadow: 0 8px 28px rgba(124,92,252,0.3);
      transition: opacity 0.2s, transform 0.2s;
      display: flex; align-items: center; justify-content: center; gap: 8px;
    }
    .btn-auth:hover { opacity: 0.88; transform: translateY(-1px); }

    .divider {
      display: flex; align-items: center; gap: 12px;
      margin: 24px 0; color: #c0bad8; font-size: 12px;
    }
    .divider::before, .divider::after {
      content: ''; flex: 1;
      height: 1px; background: rgba(124,92,252,0.12);
    }

    .back-link {
      text-align: center; margin-top: 20px;
      font-size: 12px; color: #9a94b8;
    }
    .back-link a { color: #7c5cfc; text-decoration: none; font-weight: 500; }
    .back-link a:hover { text-decoration: underline; }
  </style>
</head>
<body>

<div class="blobs">
  <div class="blob b1"></div>
  <div class="blob b2"></div>
  <div class="blob b3"></div>
</div>

<!-- NAV -->
<nav>
  <a href="/" class="logo">Travel<span>Cravings</span></a>
  <div class="nav-right">
    <a href="/listings" class="nav-link">Browse Stays</a>
    <a href="/signup" class="nav-btn">Sign Up</a>
  </div>
</nav>

<!-- MAIN -->
<div class="auth-wrap">
  <div class="auth-card">
    <div class="auth-icon">✈️</div>
    <h1 class="auth-title">Welcome back</h1>
    <p class="auth-sub">New here? <a href="/signup">Create a free account</a></p>

    <% if(error && error.length) { %>
      <div class="flash-error">
        <i class="fa-solid fa-circle-exclamation"></i>
        <%= error %>
      </div>
    <% } %>

    <form action="/login" method="POST" novalidate>
      <div class="form-group">
        <label class="form-label">USERNAME</label>
        <div class="input-wrap">
          <i class="fa-solid fa-user input-icon"></i>
          <input
            type="text"
            name="username"
            class="form-control-custom"
            placeholder="your username"
            required
            autocomplete="username"
          />
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">PASSWORD</label>
        <div class="input-wrap">
          <i class="fa-solid fa-lock input-icon"></i>
          <input
            type="password"
            name="password"
            class="form-control-custom"
            placeholder="••••••••"
            required
            autocomplete="current-password"
          />
        </div>
      </div>

      <button type="submit" class="btn-auth">
        <i class="fa-solid fa-arrow-right-to-bracket"></i>
        Log In
      </button>
    </form>

    <div class="back-link">
      <a href="/listings">← Back to listings</a>
    </div>
  </div>
</div>

<%- include('../includes/chatbot') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
