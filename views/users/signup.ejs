<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sign Up — TravelCravings</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', sans-serif;
      min-height: 100vh;
      background: #f0f4ff;
      display: flex; flex-direction: column;
      overflow-x: hidden;
    }

    .blobs { position: fixed; inset: 0; pointer-events: none; z-index: 0; overflow: hidden; }
    .blob { position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.55; }
    .b1 { width: 500px; height: 500px; background: #d4f0c8; top: -100px; right: -80px; animation: m1 14s ease-in-out infinite alternate; }
    .b2 { width: 400px; height: 400px; background: #c7b8ff; bottom: -60px; left: -80px; animation: m2 17s ease-in-out infinite alternate; }
    .b3 { width: 280px; height: 280px; background: #ffd6e8; top: 35%; left: 55%; animation: m3 12s ease-in-out infinite alternate; }
    @keyframes m1 { 0% { border-radius:60% 40% 30% 70%/60% 30% 70% 40%; transform:translate(0,0); } 100% { border-radius:40% 60% 70% 30%/40% 70% 30% 60%; transform:translate(-40px,50px); } }
    @keyframes m2 { 0% { border-radius:40% 60% 60% 40%/60% 30% 70% 40%; transform:translate(0,0); } 100% { border-radius:60% 40% 30% 70%/40% 60% 40% 60%; transform:translate(40px,-40px); } }
    @keyframes m3 { 0% { border-radius:50% 50% 60% 40%/40% 60% 50% 60%; transform:translate(0,0); } 100% { border-radius:60% 40% 40% 60%/60% 40% 60% 40%; transform:translate(-30px,30px); } }

    nav {
      position: relative; z-index: 100;
      padding: 16px 48px;
      display: flex; align-items: center; justify-content: space-between;
      background: rgba(255,255,255,0.5);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(255,255,255,0.65);
      animation: fadeDown 0.5s ease both;
    }
    @keyframes fadeDown { from { opacity:0; transform:translateY(-16px); } to { opacity:1; transform:translateY(0); } }
    .logo { font-family:'Syne',sans-serif; font-size:20px; font-weight:800; text-decoration:none; color:#1e1b3a; }
    .logo span { background:linear-gradient(90deg,#7c5cfc,#38b6ff); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
    .nav-right { display:flex; gap:16px; align-items:center; }
    .nav-link { color:#5a5478; font-size:13px; text-decoration:none; transition:color 0.2s; }
    .nav-link:hover { color:#7c5cfc; }
    .nav-btn { background:linear-gradient(135deg,#7c5cfc,#38b6ff); color:#fff; border:none; padding:9px 20px; border-radius:50px; font-size:12px; font-weight:500; text-decoration:none; cursor:pointer; box-shadow:0 4px 16px rgba(124,92,252,0.3); transition:opacity 0.2s,transform 0.15s; }
    .nav-btn:hover { opacity:0.88; transform:translateY(-1px); color:#fff; }

    .auth-wrap {
      flex:1; position:relative; z-index:10;
      display:flex; align-items:center; justify-content:center;
      padding: 40px 24px;
    }

    .auth-card {
      width:100%; max-width:440px;
      background:rgba(255,255,255,0.6);
      backdrop-filter:blur(28px); -webkit-backdrop-filter:blur(28px);
      border:1px solid rgba(255,255,255,0.85);
      border-radius:28px; padding:44px 40px;
      box-shadow:0 20px 64px rgba(124,92,252,0.12),0 4px 16px rgba(0,0,0,0.04);
      animation:cardIn 0.5s 0.1s cubic-bezier(0.34,1.2,0.64,1) both;
    }
    @keyframes cardIn { from{opacity:0;transform:translateY(28px) scale(0.97);} to{opacity:1;transform:translateY(0) scale(1);} }

    .auth-icon {
      width:54px; height:54px; border-radius:16px;
      background:linear-gradient(135deg,#7c5cfc,#38b6ff);
      display:flex; align-items:center; justify-content:center;
      font-size:22px; color:#fff; margin-bottom:24px;
      box-shadow:0 8px 24px rgba(124,92,252,0.35);
    }
    .auth-title { font-family:'Syne',sans-serif; font-size:26px; font-weight:700; color:#1e1b3a; letter-spacing:-0.8px; margin-bottom:6px; }
    .auth-sub { font-size:13px; color:#9a94b8; margin-bottom:32px; }
    .auth-sub a { color:#7c5cfc; text-decoration:none; font-weight:500; }
    .auth-sub a:hover { text-decoration:underline; }

    .flash-error {
      background:rgba(239,68,68,0.08); border:1px solid rgba(239,68,68,0.2);
      border-radius:12px; padding:10px 14px; font-size:12px; color:#dc2626;
      margin-bottom:20px; display:flex; align-items:center; gap:8px;
    }

    .form-group { margin-bottom:18px; }
    .form-label { font-size:12px; font-weight:500; color:#5a5478; letter-spacing:0.3px; margin-bottom:7px; display:block; }
    .form-control-custom {
      width:100%; background:rgba(255,255,255,0.7);
      border:1px solid rgba(124,92,252,0.18); border-radius:14px;
      padding:12px 16px 12px 38px; font-size:14px; color:#1e1b3a;
      font-family:'Inter',sans-serif; outline:none;
      transition:border-color 0.2s,box-shadow 0.2s,background 0.2s;
    }
    .form-control-custom:focus { border-color:rgba(124,92,252,0.5); box-shadow:0 0 0 4px rgba(124,92,252,0.08); background:rgba(255,255,255,0.9); }
    .form-control-custom::placeholder { color:#c0bad8; }

    .input-wrap { position:relative; }
    .input-icon { position:absolute; left:14px; top:50%; transform:translateY(-50%); color:#b0aac8; font-size:13px; pointer-events:none; }

    /* password strength */
    .strength-bar { height:3px; border-radius:4px; margin-top:6px; background:#e8e4f4; overflow:hidden; }
    .strength-fill { height:100%; border-radius:4px; width:0%; transition:width 0.3s, background 0.3s; }

    .btn-auth {
      width:100%; background:linear-gradient(135deg,#7c5cfc,#38b6ff);
      color:#fff; border:none; padding:13px 24px; border-radius:14px;
      font-size:14px; font-weight:500; font-family:'Inter',sans-serif;
      cursor:pointer; margin-top:8px;
      box-shadow:0 8px 28px rgba(124,92,252,0.3);
      transition:opacity 0.2s,transform 0.2s;
      display:flex; align-items:center; justify-content:center; gap:8px;
    }
    .btn-auth:hover { opacity:0.88; transform:translateY(-1px); }

    .terms { font-size:11px; color:#b0aac8; text-align:center; margin-top:16px; line-height:1.6; }
    .terms a { color:#7c5cfc; text-decoration:none; }

    .back-link { text-align:center; margin-top:20px; font-size:12px; color:#9a94b8; }
    .back-link a { color:#7c5cfc; text-decoration:none; font-weight:500; }
    .back-link a:hover { text-decoration:underline; }
  </style>
</head>
<body>

<div class="blobs">
  <div class="blob b1"></div>
  <div class="blob b2"></div>
  <div class="blob b3"></div>
</div>

<nav>
  <a href="/" class="logo">Travel<span>Cravings</span></a>
  <div class="nav-right">
    <a href="/listings" class="nav-link">Browse Stays</a>
    <a href="/login" class="nav-btn">Log In</a>
  </div>
</nav>

<div class="auth-wrap">
  <div class="auth-card">
    <div class="auth-icon">🌍</div>
    <h1 class="auth-title">Create account</h1>
    <p class="auth-sub">Already have one? <a href="/login">Log in instead</a></p>

    <% if(error && error.length) { %>
      <div class="flash-error">
        <i class="fa-solid fa-circle-exclamation"></i>
        <%= error %>
      </div>
    <% } %>

    <form action="/signup" method="POST" novalidate>
      <div class="form-group">
        <label class="form-label">USERNAME</label>
        <div class="input-wrap">
          <i class="fa-solid fa-user input-icon"></i>
          <input type="text" name="username" class="form-control-custom" placeholder="choose a username" required autocomplete="username"/>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">EMAIL</label>
        <div class="input-wrap">
          <i class="fa-solid fa-envelope input-icon"></i>
          <input type="email" name="email" class="form-control-custom" placeholder="you@example.com" required autocomplete="email"/>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">PASSWORD</label>
        <div class="input-wrap">
          <i class="fa-solid fa-lock input-icon"></i>
          <input type="password" name="password" id="pwdInput" class="form-control-custom" placeholder="••••••••" required autocomplete="new-password"/>
        </div>
        <div class="strength-bar"><div class="strength-fill" id="strengthFill"></div></div>
      </div>

      <button type="submit" class="btn-auth">
        <i class="fa-solid fa-user-plus"></i>
        Create Account
      </button>
    </form>

    <p class="terms">
      By signing up you agree to our <a href="#">Terms</a> and <a href="#">Privacy Policy</a>
    </p>

    <div class="back-link">
      <a href="/listings">← Back to listings</a>
    </div>
  </div>
</div>

<%- include('../includes/chatbot') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // Password strength indicator
  const pwd = document.getElementById('pwdInput');
  const fill = document.getElementById('strengthFill');
  if (pwd && fill) {
    pwd.addEventListener('input', () => {
      const v = pwd.value;
      let score = 0;
      if (v.length >= 6) score++;
      if (v.length >= 10) score++;
      if (/[A-Z]/.test(v)) score++;
      if (/[0-9]/.test(v)) score++;
      if (/[^A-Za-z0-9]/.test(v)) score++;
      const pct = (score / 5) * 100;
      const colors = ['#ef4444','#f97316','#eab308','#22c55e','#7c5cfc'];
      fill.style.width = pct + '%';
      fill.style.background = colors[score - 1] || '#e8e4f4';
    });
  }
</script>
</body>
</html>
